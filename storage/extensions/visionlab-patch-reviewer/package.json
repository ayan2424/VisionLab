{
  "name": "visionlab-patch-reviewer",
  "displayName": "VisionLab Patch Reviewer",
  "description": "Automated Multi-File Background Patch Reviewer for VisionLab",
  "version": "1.0.0",
  "publisher": "VisionLab",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "visionlab.showPatchPreview",
        "title": "Review AI Patch"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "build": "vsce package"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1",
    "@vscode/vsce": "^2.19.0"
  },
  "dependencies": {
    "pusher-js": "^8.3.0",
    "laravel-echo": "^1.15.3"
  }
}
