{
  "name": "VisionLab-collab",
  "displayName": "VisionLab Collab",
  "description": "Real-time collaboration for VisionLab",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "VisionLab.startCollab",
        "title": "VisionLab: Start Collaboration"
      },
      {
        "command": "VisionLab.startImplementation",
        "title": "VisionLab: Start AI Implementation"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "VisionLab-collab-view",
          "title": "VisionLab Collab",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "VisionLab-collab-view": [
        {
          "type": "webview",
          "id": "VisionLab.collabWebview",
          "name": "Collaboration"
        }
      ]
    }
  }
}